  "description": "Clean, minimal, tech-forward design with geometric elements",
  "avatar": "🚀",
  "theme": {
    "colors": {
      "primary": "#00D4FF",
      "secondary": "#FF6B00",
      "accent": "#00FF88",
      "background": "#0A0A0F",
      "surface": "#1A1A2E",
      "text": "#FFFFFF"
    },
